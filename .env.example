# Server
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info
# Set to true only when running behind a trusted reverse proxy / load balancer,
# so client IPs are taken from X-Forwarded-For for rate limiting.
TRUST_PROXY=false

# Redis (system of record — run with AOF enabled; see compose.yaml)
REDIS_URL=redis://localhost:6379

# Password policy (NIST SP 800-63B-4: min 15 chars for single-factor auth,
# no composition rules, blocklist screening, never truncate)
PASSWORD_MIN_LENGTH=15
PASSWORD_MAX_LENGTH=256

# Argon2id parameters (OWASP Password Storage Cheat Sheet minimums)
HASH_MEMORY_KIB=19456
HASH_TIME_COST=2
HASH_PARALLELISM=1
# Each in-flight hash reserves HASH_MEMORY_KIB of RAM. This cap bounds
# worst-case hashing memory to HASH_MAX_CONCURRENCY * HASH_MEMORY_KIB.
HASH_MAX_CONCURRENCY=8

# Rate limiting (Redis-backed fixed windows — consistent across replicas)
RATE_LIMIT_IP_MAX=100
RATE_LIMIT_IP_WINDOW_SECONDS=60
RATE_LIMIT_LOGIN_FAILURES_MAX=10
RATE_LIMIT_LOGIN_FAILURES_WINDOW_SECONDS=900
