{
  "name": "auth-api",
  "version": "1.0.1",
  "description": "Internal authentication API — Fastify 5, TypeScript 6, Redis 8, Argon2id. RFC 9457 errors, OpenAPI, distributed rate limiting.",
  "type": "module",
  "license": "MIT",
  "author": "Arash Mozhdehi <amojdehi@gmail.com>",
  "engines": {
    "node": ">=24.0.0"
  },
  "overrides": {
    "openapi-typescript": {
      "typescript": "$typescript"
    },
    "qs": ">=6.15.2",
    "uuid": ">=11.1.1"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json && npm run copy:assets",
    "copy:assets": "mkdir -p dist/data && cp src/data/common-passwords.txt dist/data/",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . && prettier --check .",
    "lint:fix": "eslint . --fix && prettier --write .",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:coverage": "vitest run --coverage",
    "openapi:generate": "tsx scripts/generate-openapi.ts && prettier --write openapi.json --log-level silent",
    "openapi:lint": "spectral lint openapi.json --fail-severity warn",
    "client:generate": "openapi-typescript openapi.json -o client/api.d.ts",
    "bench": "tsx bench/run.ts",
    "test:mutation": "stryker run"
  },
  "dependencies": {
    "@fastify/helmet": "^13.1.0",
    "@fastify/otel": "^0.20.1",
    "@fastify/swagger": "^9.8.1",
    "@fastify/type-provider-typebox": "^6.1.0",
    "@fastify/under-pressure": "^9.1.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
    "@opentelemetry/resources": "^2.9.0",
    "@opentelemetry/sdk-node": "^0.220.0",
    "@opentelemetry/semantic-conventions": "^1.43.0",
    "@scalar/fastify-api-reference": "^1.62.5",
    "argon2": "^0.44.0",
    "close-with-grace": "^2.2.0",
    "fastify": "^5.10.0",
    "p-limit": "^7.0.0",
    "pino": "^10.0.0",
    "prom-client": "^15.1.3",
    "redis": "^6.1.0",
    "typebox": "^1.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@stoplight/spectral-cli": "^6.15.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@testcontainers/redis": "^12.0.0",
    "@types/autocannon": "^7.12.7",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "ajv": "^8.20.0",
    "autocannon": "^8.0.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.0.0",
    "fast-check": "^4.9.0",
    "openapi-typescript": "^7.9.0",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.9.5",
    "testcontainers": "^12.0.0",
    "tsx": "^4.23.1",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.0"
  }
}
