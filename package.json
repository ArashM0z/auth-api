{
  "name": "auth-api",
  "version": "1.0.0",
  "description": "Internal authentication API — Fastify 5, TypeScript 6, Redis 8, Argon2id. RFC 9457 errors, OpenAPI, distributed rate limiting.",
  "type": "module",
  "license": "MIT",
  "author": "Arash Mozhdehi <amojdehi@gmail.com>",
  "engines": {
    "node": ">=24.0.0"
  },
  "overrides": {
    "openapi-typescript": {
      "typescript": "$typescript"
    }
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json && npm run copy:assets",
    "copy:assets": "mkdir -p dist/data && cp src/data/common-passwords.txt dist/data/",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . && prettier --check .",
    "lint:fix": "eslint . --fix && prettier --write .",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:coverage": "vitest run --coverage",
    "openapi:generate": "tsx scripts/generate-openapi.ts",
    "openapi:lint": "spectral lint openapi.json --fail-severity warn",
    "client:generate": "openapi-typescript openapi.json -o client/api.d.ts",
    "bench": "tsx bench/run.ts"
  },
  "dependencies": {
    "@fastify/helmet": "^13.0.2",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^6.0.0",
    "@fastify/type-provider-typebox": "^6.1.0",
    "@fastify/under-pressure": "^9.0.0",
    "argon2": "^0.44.0",
    "close-with-grace": "^2.2.0",
    "fastify": "^5.10.0",
    "p-limit": "^7.0.0",
    "pino": "^10.0.0",
    "redis": "^6.1.0",
    "typebox": "^1.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@stoplight/spectral-cli": "^6.15.0",
    "@testcontainers/redis": "^12.0.0",
    "@types/autocannon": "^7.12.7",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "ajv": "^8.20.0",
    "autocannon": "^8.0.0",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.0.0",
    "fast-check": "^4.0.0",
    "openapi-typescript": "^7.9.0",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.6.0",
    "testcontainers": "^12.0.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.0"
  }
}
