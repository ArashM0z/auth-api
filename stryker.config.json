{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "_comment": "Mutation testing: mutate the pure-logic core and prove the unit tests kill the mutants. Scoped to modules the fast unit suite covers (no Redis/Docker), so it runs in CI in ~a minute.",
  "packageManager": "npm",
  "testRunner": "vitest",
  "vitest": { "configFile": "vitest.unit.config.ts" },
  "mutate": ["src/domain/password-policy.ts", "src/domain/username.ts"],
  "reporters": ["progress", "clear-text", "html"],
  "htmlReporter": { "fileName": "reports/mutation/index.html" },
  "coverageAnalysis": "perTest",
  "thresholds": { "high": 90, "low": 80, "break": 80 }
}
